{
  "name": "cx-survey-platform",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:init": "node scripts/dev-db.mjs init",
    "db:start": "node scripts/dev-db.mjs start",
    "db:stop": "node scripts/dev-db.mjs stop",
    "db:migrate": "node scripts/dev-db.mjs migrate",
    "db:reset": "node scripts/dev-db.mjs reset",
    "db:status": "node scripts/dev-db.mjs status",
    "db:native:init": "scripts/dev-db.sh init",
    "db:native:start": "scripts/dev-db.sh start",
    "db:native:stop": "scripts/dev-db.sh stop",
    "db:native:migrate": "scripts/dev-db.sh migrate",
    "db:native:reset": "scripts/dev-db.sh reset",
    "test:db-manager": "node --test scripts/dev-db.test.mjs",
    "seed": "pnpm --filter @ok/web seed"
  },
  "devDependencies": {
    "@electric-sql/pglite": "0.4.5",
    "@electric-sql/pglite-socket": "0.1.5",
    "turbo": "^2.5.8",
    "typescript": "^5"
  }
}
