# --- Database (local development) ---
# Connection string for the local PostgreSQL instance managed by scripts/dev-db.sh.
# The app connects as the non-superuser role `cx_app` so row-level security applies.
DATABASE_URL=postgres://cx_app@localhost:54329/cx_platform

# Service connection for local auth, identity administration, anonymous respondent flow, migrations, and seed.
# Keep server-only; never expose it to browser code.
DATABASE_ADMIN_URL=postgres://postgres@localhost:54329/cx_platform

# --- Web app ---
# Secret used to sign local development session cookies (any long random string).
SESSION_SECRET=

# Base URL of the web app, used to build absolute public survey links.
APP_BASE_URL=http://localhost:3000

# --- Analytics service ---
# Base URL of the Python analytics API (apps/analytics).
ANALYTICS_URL=http://localhost:8000

# Same random bearer secret in web and analytics environments outside local development.
ANALYTICS_API_SECRET=
APP_ENV=development

# --- Supabase (production path; not used in local no-Docker development) ---
# When a Supabase project exists, these switch data access to supabase-js + Supabase Auth.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Firecrawl import route (pre-existing research tooling) ---
IMPORT_API_SECRET=
FIRECRAWL_API_KEY=
