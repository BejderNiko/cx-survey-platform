# --- Local database engine ---
# Local development runs on PGlite (PostgreSQL compiled to WebAssembly) via
# `pnpm db:init` / `pnpm db:start` (scripts/dev-db.mjs). No PostgreSQL
# installation, Docker, WSL, psql, or Supabase CLI is required, which is why
# it is the default on locked-down Windows machines. Values: pglite | native.
# `native` targets the scripts/dev-db.sh PostgreSQL 16 cluster (Linux/CI —
# the authoritative database gate). PGlite mode is rejected on Vercel
# Preview/Production and under NODE_ENV=production.
LOCAL_DATABASE_ENGINE=pglite

# --- Database (local development) ---
# PGlite engine (default): database name is `postgres` on 127.0.0.1:54329.
# The app connects as `cx_app`; note that PGlite executes every connection as
# `postgres` regardless of this username, so authenticated transactions run an
# explicit `SET LOCAL ROLE cx_app` in PGlite mode to keep RLS enforced
# (see docs/hosted-role-and-rls.md).
DATABASE_URL=postgres://cx_app@127.0.0.1:54329/postgres

# Service connection for local auth, identity administration, anonymous
# respondent flow, migrations, and seed. Keep server-only; never expose it to
# browser code.
DATABASE_ADMIN_URL=postgres://postgres@127.0.0.1:54329/postgres

# Native engine equivalents (LOCAL_DATABASE_ENGINE=native, database
# `cx_platform`, used by Linux CI):
#   DATABASE_URL=postgres://cx_app@127.0.0.1:54329/cx_platform
#   DATABASE_ADMIN_URL=postgres://postgres@127.0.0.1:54329/cx_platform
# Optional port override for both engines (default 54329):
#   CX_DB_PORT=54329

# --- Web app ---
# Secret used to sign local development session cookies (any long random string).
SESSION_SECRET=

# Base URL of the web app, used to build absolute public survey links.
APP_BASE_URL=http://localhost:3000

# --- Analytics service ---
# Base URL of the Python analytics API (apps/analytics).
ANALYTICS_URL=http://localhost:8000

# Same random bearer secret in web and analytics environments outside local development.
ANALYTICS_API_SECRET=
APP_ENV=development

# --- Supabase (hosted path; never PGlite) ---
# Hosted staging/production run on Supabase managed PostgreSQL. These switch
# data access to supabase-js + Supabase Auth when a Supabase project exists.
# On Vercel Preview/Production, DATABASE_URL/DATABASE_ADMIN_URL must point at
# the hosted database; loopback targets and LOCAL_DATABASE_ENGINE=pglite are
# rejected there.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Firecrawl import route (pre-existing research tooling) ---
IMPORT_API_SECRET=
FIRECRAWL_API_KEY=
